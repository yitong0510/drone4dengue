# ML Service Environment Configuration
# Copy this to .env and update with your actual values

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5001

# Model Configuration
MODELS_DIR=models
CACHE_TTL=10800  # 3 hours in seconds

# Weather API Configuration (if using external weather service)
WEATHER_API_KEY=your-weather-api-key
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=prediction_service.log

# Performance Configuration
MAX_WORKERS=4
REQUEST_TIMEOUT=30
