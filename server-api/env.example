# Server API Environment Configuration
# Copy this to .env and update with your actual values

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/dengue_db"

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ML Service Configuration
ML_SERVICE_URL=http://localhost:5001

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Configuration
PORT=4000
NODE_ENV=development
API_BASE_URL=http://localhost:4000

# Firebase Storage Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# IMPORTANT: Use ONLY ONE of the options below, not all three!
# If multiple are set, FIREBASE_SERVICE_ACCOUNT_JSON takes precedence, with fallback to individual vars.

# Option 1: Paste the PEM key directly (works locally, but can have newline issues on cloud hosts)
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# Option 2: Use a base64-encoded PEM to avoid newline issues on hosts like Render (RECOMMENDED for production)
# To encode: echo "$FIREBASE_PRIVATE_KEY" | base64 -w0
# FIREBASE_PRIVATE_KEY_BASE64=LS0tLS1CRUdJTiBQUklWQVRFIEtFWS0tLS0t...

# Option 3: Provide the entire service account JSON (literal or base64 encoded)
# For base64: cat service-account.json | base64 -w0
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n..."}'
# OR base64-encoded:
# FIREBASE_SERVICE_ACCOUNT_JSON=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...

# Email Configuration (if using email features)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Twilio Configuration (if using SMS features)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number
