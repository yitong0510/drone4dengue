// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                        String                  @id @default(uuid())
  name                      String                  @unique
  code                      String                  @unique // e.g., "COMP001"
  description               String?
  isActive                  Boolean                 @default(true)
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  emailNotifications        Boolean                 @default(true)
  smsNotifications          Boolean                 @default(false)
  alertFrequency            String                  @default("immediate") // "immediate", "daily", "weekly"
  alertThreshold            String                  @default("medium") // "low", "medium", "high"
  predictionModelParameters Json? // { temperatureWeight: 0.35, rainfallWeight: 0.40, populationDensityWeight: 0.25 }
  syncMode                  String                  @default("automatic") // "automatic", "manual"
  advancedSettings          Json? // { dataRetentionPolicy: {...}, apiAccess: {...}, systemBackup: {...} }
  users                     User[]
  locations                 CompanyLocation[]
  drones                    Drone[]
  images                    Image[]
  reports                   Report[]
  predictions               CompanyPrediction[]
  breedingAreaDetections    BreedingAreaDetection[]
  notifications             Notification[]
}

model CompanyLocation {
  id                     String                  @id @default(uuid())
  name                   String
  address                String?
  latitude               Float?
  longitude              Float?
  isActive               Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  companyId              String
  company                Company                 @relation(fields: [companyId], references: [id])
  weather                Weather[]
  predictions            CompanyPrediction[]
  drones                 Drone[]
  images                 Image[]
  breedingAreaDetections BreedingAreaDetection[]

  @@unique([name, companyId])
}

model User {
  id              String              @id @default(uuid())
  userId          String              @unique // for display e.g. U-001
  email           String              @unique
  password        String? // Nullable for OAuth users (Google Sign-In)
  name            String
  role            String // 'admin' or 'user'
  status          String // e.g. "Verified", "Pending"
  username        String?
  phone           String?             @unique
  address         String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  organization    String?
  resetCode       String? // for password reset
  resetCodeExpiry DateTime? // for password reset
  otpCode         String? // for OTP verification
  otpExpiry       DateTime? // for OTP verification
  // OAuth fields
  authProvider    String              @default("email") // "email" or "google"
  googleId        String?             @unique // Firebase UID for Google users
  profilePicture  String? // Google profile picture URL
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id])
  drones          Drone[]
  reports         Report[]
  alerts          Alert[]
  notifications   Notification[]
  deviceTokens    DeviceToken[]
  locationAlerts  UserLocationAlert[]
}

model Drone {
  id                String           @id @default(uuid())
  droneId           String           @unique // Display ID like DRN-001
  name              String
  model             String // Drone model (e.g., DJI Phantom 4 Pro)
  serial            String           @unique
  operationalArea   String // Operational area/location
  status            String           @default("Operational") // Operational, Maintenance, Inactive
  registrationDate  DateTime         @default(now())
  userId            String?
  user              User?            @relation(fields: [userId], references: [id])
  companyId         String
  company           Company          @relation(fields: [companyId], references: [id])
  companyLocationId String?
  companyLocation   CompanyLocation? @relation(fields: [companyLocationId], references: [id])
  images            Image[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([companyId])
  @@index([status])
  @@index([droneId])
  @@index([companyLocationId])
}

model Image {
  id                     String                  @id @default(uuid())
  url                    String
  filename               String // Original filename
  fileSize               Int // File size in bytes
  mimeType               String // MIME type (image/jpeg, image/png, etc.)
  width                  Int? // Image width in pixels
  height                 Int? // Image height in pixels
  description            String? // Optional description
  isProcessed            Boolean                 @default(false) // Whether image has been processed for analysis
  sourceType             String                  @default("upload") // "upload" or "video_frame"
  droneId                String
  drone                  Drone                   @relation(fields: [droneId], references: [id])
  companyId              String
  company                Company                 @relation(fields: [companyId], references: [id])
  companyLocationId      String?
  companyLocation        CompanyLocation?        @relation(fields: [companyLocationId], references: [id])
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  breedingAreaDetections BreedingAreaDetection[]

  @@index([droneId])
  @@index([companyId])
  @@index([companyLocationId])
  @@index([isProcessed])
  @@index([sourceType])
}

model Weather {
  id                String          @id @default(uuid())
  date              DateTime
  temperature       Float
  humidity          Float
  rainfall          Float
  location          String
  companyLocationId String
  companyLocation   CompanyLocation @relation(fields: [companyLocationId], references: [id])
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([date, location, companyLocationId])
}

model DengueData {
  id            String    @id @default(uuid())
  location      String
  date          DateTime
  activeCases   Int?
  totalCases    Int?
  days_duration Int?
  coverageArea  String?
  status        String?
  source        String?
  latitude      Float?
  longitude     Float?
  country       String? // Detailed address components from reverse geocoding // Malaysia 
  state         String? // Selangor, Kuala Lumpur, etc.
  district      String? // More granular than state
  city          String? // City name
  suburb        String? // Suburb/neighborhood
  postcode      String? // Postal code
  road          String? // Street name
  houseNumber   String? // House/building number
  boundingBox   Json? // Geographic and address metadata // [south, north, west, east] coordinates
  displayName   String? // Full formatted address from Nominatim
  isGeocoded    Boolean   @default(false) // Reverse geocoding status tracking
  geocodedAt    DateTime?
  geocodeError  String? // Store any geocoding errors
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isGeocoded])
  @@index([country])
  @@index([state])
  @@index([city])
  @@index([postcode])
}

model Alert {
  id        String   @id @default(uuid())
  message   String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Report {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  description String
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
}

model Recommendation {
  id            String   @id @default(uuid())
  risk          String // 'high', 'medium', 'low'
  title         String
  details       String
  referenceLink String? // URL to source/reference for the recommendation
  createdAt     DateTime @default(now())
}

model CompanyPrediction {
  id                String           @id @default(uuid())
  companyId         String
  company           Company          @relation(fields: [companyId], references: [id])
  companyLocationId String?
  companyLocation   CompanyLocation? @relation(fields: [companyLocationId], references: [id])
  latitude          Float
  longitude         Float
  riskScore         Float
  model1Score       Float? // Historical cases model score
  model2Score       Float? // Weather-based model score
  model3Score       Float? // Breeding area detection model score
  combinedScore     Float? // Combined score from all three models
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([companyId])
  @@index([companyLocationId])
  @@index([createdAt])
}

model PredictionLog {
  id          String   @id @default(uuid())
  latitude    Float
  longitude   Float
  userId      String?
  riskScore   Float?
  requestedAt DateTime @default(now())

  @@index([requestedAt])
  @@index([userId])
}

model BreedingAreaDetection {
  id                String           @id @default(uuid())
  imageId           String
  image             Image            @relation(fields: [imageId], references: [id])
  companyId         String
  company           Company          @relation(fields: [companyId], references: [id])
  companyLocationId String?
  companyLocation   CompanyLocation? @relation(fields: [companyLocationId], references: [id])
  breedingAreaScore Float // Confidence score for breeding area detection (0-1)
  detectedObjects   Json? // Full detection results from Roboflow API
  boundingBoxes     Json? // Bounding boxes of detected breeding areas
  riskLevel         String // "high", "medium", "low" based on detection score
  processingStatus  String           @default("pending") // "pending", "processing", "completed", "failed"
  errorMessage      String?
  processedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([imageId])
  @@index([companyId])
  @@index([companyLocationId])
  @@index([processingStatus])
  @@index([riskLevel])
}

model Notification {
  id        String    @id @default(uuid())
  title     String
  message   String
  type      String // 'prediction', 'dengue_case', 'drone', 'drone_image', 'location', 'daily_prediction'
  userId    String? // null for company-wide notifications
  user      User?     @relation(fields: [userId], references: [id])
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  isRead    Boolean   @default(false)
  metadata  Json? // Additional data like riskLevel, location, etc.
  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@index([userId])
  @@index([companyId])
  @@index([isRead])
  @@index([createdAt])
  @@index([type])
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushToken String   @unique
  platform  String // 'ios' or 'android'
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([pushToken])
  @@index([isActive])
}

model UserLocationAlert {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String // User-defined name for the alert location
  latitude    Float
  longitude   Float
  boundingBox Json // [minLat, maxLat, minLon, maxLon] from Nominatim
  address     String? // Display name from Nominatim reverse geocoding
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
}
